# Repo-wide ignores. Subdirectory-specific ignores live in
# backend/.gitignore and mobile/.gitignore.

# OS / editor cruft
.DS_Store
.idea/
.vscode/
*.swp

# Python tool caches that can land at the repo root when running scripts
# from here (e.g. prototype_review.py).
__pycache__/
*.py[cod]
.ruff_cache/
.mypy_cache/
.pytest_cache/

# Anything sensitive
.env
.env.local
*.pem

# Local agent / tool state — never useful in version control.
.claude/
.playwright-mcp/

# Local SQLite scratch DB the latency probe writes on each run.
backend/.local-probe.db

# Ad-hoc debug screenshots that land at the repo root from local runs.
/camera-live.png
/live-capture-result.png
/result-current.png
/result-error.png
/scan-after-reset.png
/scan-view.png
/verify-error-503.png

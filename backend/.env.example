DATABASE_URL=postgresql+asyncpg://proofread:proofread@localhost:5432/proofread

STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./.storage
S3_BUCKET=
S3_REGION=us-east-1

OCR_PROVIDER=mock
GOOGLE_VISION_CREDENTIALS_PATH=

RULE_DEFINITIONS_PATH=app/rules/definitions
CANONICAL_TEXTS_PATH=app/canonical

AUTH_MODE=stub
AUTH0_DOMAIN=
AUTH0_AUDIENCE=

HEALTH_WARNING_MAX_EDIT_DISTANCE=0

# Claude vision extractor — required when VISION_EXTRACTOR=claude
ANTHROPIC_API_KEY=
# Haiku 4.5 is the verify-path default: character-identical OCR output to
# Sonnet 4.6 on the bundled samples, ~2× faster wall-clock (3.8 s vs 7.5 s
# on a real beer label). The same tier already adjudicates the Government
# Warning second-pass, so trusting it for the rest of the verbatim
# transcription is consistent. Override to `claude-sonnet-4-6` (or Opus)
# only when chasing a specific accuracy regression.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# Same tier as the primary now, but kept as a separate env var so the
# second pass can be tuned independently if Haiku ever regresses on the
# warning-text task. Runs concurrently with the primary so its cost is
# hidden in wall-clock terms.
ANTHROPIC_HEALTH_WARNING_MODEL=claude-haiku-4-5-20251001
ENABLE_HEALTH_WARNING_SECOND_PASS=true
VISION_EXTRACTOR=claude

# Local Qwen3-VL fallback. When ENABLE_QWEN_FALLBACK=true and QWEN_VL_BASE_URL
# is set to an OpenAI-compatible chat-completions endpoint (vLLM, Ollama,
# LM Studio, llama.cpp --api), the verify + scan extractors fall back to
# Qwen3-VL when the Anthropic call raises ExtractorUnavailable.
ENABLE_QWEN_FALLBACK=false
QWEN_VL_BASE_URL=
QWEN_VL_MODEL=qwen3-vl
QWEN_VL_API_KEY=

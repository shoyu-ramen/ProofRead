DATABASE_URL=postgresql+asyncpg://proofread:proofread@localhost:5432/proofread

STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./.storage
S3_BUCKET=
S3_REGION=us-east-1

OCR_PROVIDER=mock
GOOGLE_VISION_CREDENTIALS_PATH=

RULE_DEFINITIONS_PATH=app/rules/definitions
CANONICAL_TEXTS_PATH=app/canonical

AUTH_MODE=stub
AUTH0_DOMAIN=
AUTH0_AUDIENCE=

HEALTH_WARNING_MAX_EDIT_DISTANCE=0

# Field-level confidence below this floor downgrades a required rule to
# ADVISORY. Single source of truth — extractors and the rule engine both
# import this value, so a tuning change here propagates atomically.
LOW_CONFIDENCE_THRESHOLD=0.6

# Verify-path safety limits.
MAX_IMAGE_BYTES=15728640         # 15 MiB upload cap
VERIFY_REQUEST_TIMEOUT_S=30.0    # FastAPI-level wall-clock cap per /v1/verify

# Claude vision extractor — required when VISION_EXTRACTOR=claude
ANTHROPIC_API_KEY=
# Haiku 4.5 is the verify-path default: character-identical OCR output to
# Sonnet 4.6 on the bundled samples, ~2× faster wall-clock (3.8 s vs 7.5 s
# on a real beer label). Override to `claude-sonnet-4-6` (or Opus) only
# when chasing a specific accuracy regression.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# DIFFERENT family from the primary — SPEC §0.5 calls for two *independent*
# reads of the Government Warning, and two reads from the same Haiku version
# tend to agree on the same OCR mistake. Sonnet 4.6 here keeps the cross-
# check genuinely independent while still finishing inside the 8 s
# second-pass timeout. Runs concurrently with the primary so its cost is
# hidden in wall-clock terms.
ANTHROPIC_HEALTH_WARNING_MODEL=claude-sonnet-4-6
ENABLE_HEALTH_WARNING_SECOND_PASS=true
VISION_EXTRACTOR=claude

# Local Qwen3-VL fallback. When ENABLE_QWEN_FALLBACK=true and QWEN_VL_BASE_URL
# is set to an OpenAI-compatible chat-completions endpoint (vLLM, Ollama,
# LM Studio, llama.cpp --api), the verify + scan extractors fall back to
# Qwen3-VL when the Anthropic call raises ExtractorUnavailable.
ENABLE_QWEN_FALLBACK=false
QWEN_VL_BASE_URL=
QWEN_VL_MODEL=qwen3-vl
QWEN_VL_API_KEY=

# Telemetry (all optional — missing values = silent no-op so local dev
# never ships data anywhere). Install the `telemetry` extra to enable:
#   pip install -e '.[telemetry]'
SENTRY_DSN=
HONEYCOMB_API_KEY=
OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io
DEPLOY_ENVIRONMENT=dev
DEPLOY_RELEASE=

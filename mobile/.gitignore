# Scoped to this directory; do not modify repo-wide gitignore.

# Dependencies
node_modules/

# Expo / Metro / build artifacts
.expo/
.expo-shared/
dist/
web-build/

# Native build outputs (when prebuild is run)
ios/build/
android/build/
android/app/build/
android/.gradle/
android/.idea/

# Expo prebuild output — generated locally via `npx expo prebuild`,
# regenerated on EAS build. Treating ios/ and android/ as generated for
# now keeps the 290MB Pods cache out of git; if/when we need to hand-
# edit native code, drop the whole-folder ignore and selectively
# ignore Pods/ + xcuserdata/ instead.
ios/
android/

# Env / local config
.env
.env.local
.env.*.local

# Logs / debug
*.log
npm-debug.*
yarn-debug.*
yarn-error.*

# Misc
.DS_Store
*.pem
*.tsbuildinfo
